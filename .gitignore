FINAL/archive.zip

# Model checkpoints / weights (>100MB GitHub limit; regenerable via training)
*.safetensors
FINAL/**/checkpoint-*/
FINAL/**/training_args.bin
FINAL/**/optimizer.pt

# Stale Kaggle run output trees (superseded by the Modal sweep; heavy artifacts)
FINAL/kaggle_runs/outputs/
FINAL/kaggle_runs/outputs_live/
FINAL/kaggle_runs/outputs_final/

# Transient caches/logs
FINAL/__pycache__/

# NOTE: FINAL/modal_out/*.npy logits are intentionally NOT ignored — committed for reproducibility.
